generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model VisitorLog {
  id            String   @id @default(cuid())
  dateTime      DateTime @default(now())
  unitNumber    String
  visitorName   String
  visitType     String
  conciergeName String
  comments      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model JobApplication {
  id                     String   @id @default(cuid())
  fullName               String
  phone                  String
  email                  String
  address                String
  city                   String
  state                  String
  zip                    String
  authorized             String
  eighteenPlus           String
  position               String
  heardAbout             String?
  desiredPay             String?
  shift1                 String?
  shift2                 String?
  shift3                 String?
  holidays               String?
  overnights             String?
  transportation         String?
  recentCompany          String?
  recentPosition         String?
  recentDates            String?
  recentLeaving          String?
  prevCompany            String?
  prevPosition           String?
  prevDates              String?
  prevLeaving            String?
  priorExperience        String?
  experienceDescription  String?
  skills                 String?
  bilingualLanguages     String?
  backgroundCheck        Boolean  @default(false)
  certification          Boolean  @default(false)
  status                 String   @default("New")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
